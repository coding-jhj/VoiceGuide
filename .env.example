# VoiceGuide 환경 변수 예시
# 복사 후 .env로 저장하고 값을 채워주세요

# ngrok 인증 토큰 (서버 외부 접근용)
NGROK_AUTH_TOKEN=

# 서버 포트 (기본값: 8000)
PORT=8000

# ElevenLabs TTS API 키 (https://elevenlabs.io에서 발급)
ELEVENLABS_API_KEY=

# OpenAI API 키 — 옷 매칭/패턴 분석 기능(GPT-4o Vision)에 필요
OPENAI_API_KEY=

# Supabase / PostgreSQL (서버_DB — 신유득 작업, 선택 사항)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# 또는 개별 변수로 설정
# PGHOST=
# PGPORT=5432
# PGDATABASE=postgres
# PGUSER=postgres
# PGPASSWORD=
# PGSSLMODE=require
POSTGRES_ITEMS_TABLE=items
