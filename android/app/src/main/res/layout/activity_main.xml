<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <EditText
        android:id="@+id/etServerUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="서버 URL  예) http://192.168.x.x:8000"
        android:inputType="textUri"
        android:padding="10dp"
        android:textSize="13sp"
        android:background="#1A1A1A"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888" />

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 음성 안내 결과 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:text="분석 시작 버튼을 누르세요"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:padding="16dp"
        android:background="#1A1A1A"
        android:lineSpacingMultiplier="1.4" />

    <TextView
        android:id="@+id/tvDetected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="44dp"
        android:text="인식: 대기 중"
        android:textSize="15sp"
        android:textColor="#D6EFFF"
        android:gravity="center"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#0B1B24"
        android:maxLines="3" />

    <!-- 모드 / 방향 상태 표시 -->
    <TextView
        android:id="@+id/tvMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="모드: 장애물  |  방향: 정면"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#111111" />

    <!-- 버튼 행 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnToggle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="분석 시작"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#1565C0" />

        <Button
            android:id="@+id/btnStt"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="음성 명령"
            android:textSize="16sp"
            android:backgroundTint="#2E7D32" />

    </LinearLayout>

</LinearLayout>
